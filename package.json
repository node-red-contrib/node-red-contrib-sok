{
  "name": "node-red-contrib-sok",
  "version": "0.0.1",
  "description": "Simple Node-RED BLE reader for SOK smart batteries.",
  "main": "lib/index.js",
  "bin": {
    "sok-battery": "./bin/sok-battery.js"
  },
  "node-red": {
    "nodes": {
      "sok-battery-device": "nodes/sok-battery-device.js",
      "sok-battery-get": "nodes/sok-battery-get.js"
    }
  },
  "scripts": {
    "test": "node --test",
    "read": "node ./bin/sok-battery.js read"
  },
  "dependencies": {
    "dbus-next": "^0.10.2"
  },
  "optionalDependencies": {
    "@abandonware/noble": "^1.9.2-26"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "node-red",
    "sok",
    "battery",
    "bluetooth",
    "ble",
    "modbus"
  ],
  "license": "MIT"
}
