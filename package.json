{
  "name": "node-red-contrib-sok",
  "version": "0.0.1",
  "description": "Simple Node-RED BLE reader for SOK smart batteries.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "nodes",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "sok-battery": "./bin/sok-battery.js"
  },
  "node-red": {
    "nodes": {
      "sok-battery-device": "nodes/sok-battery-device.js",
      "sok-battery-get": "nodes/sok-battery-get.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -p tsconfig.json --build --clean",
    "discover": "npm run build --silent && node ./bin/sok-battery.js discover",
    "get": "npm run build --silent && node ./bin/sok-battery.js get",
    "lint": "eslint .",
    "check": "npm run build && npm run lint && npm test",
    "test": "npm run build --silent && node --test"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "commander": "^14.0.3",
    "dbus-next": "^0.10.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "keywords": [
    "node-red",
    "sok",
    "battery",
    "bluetooth",
    "ble",
    "modbus"
  ],
  "license": "MIT"
}
